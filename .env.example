# GitHub Pages用の設定
GITHUB_PAGES=true

# Googleスプレッドシート連携設定
# 以下のURLは、Google Apps Scriptで公開したエンドポイントのURLを設定してください

# グループ情報を取得するスプレッドシートのURL
# 例: https://script.google.com/macros/d/{SCRIPT_ID}/usercontent/exec?type=groups
VITE_GOOGLE_SHEETS_GROUPS_URL=

# イベント情報を取得するスプレッドシートのURL
# 例: https://script.google.com/macros/d/{SCRIPT_ID}/usercontent/exec?type=events
VITE_GOOGLE_SHEETS_EVENTS_URL=

# 注：環境変数は VITE_ プレフィックスが必要です（Viteで使用するため）
